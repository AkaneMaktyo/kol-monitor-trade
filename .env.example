# Telegram 用户账号监听配置
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash_here
TELEGRAM_SESSION_PATH=data/telegram_user
TELEGRAM_PROXY_URL=socks5://127.0.0.1:7897
TELEGRAM_MONITOR_CHANNELS=
# 留空不监听任何 Telegram 频道；填 * 才监听全部可见频道。

# Discord 配置
# bot：官方 Bot 模式；self：用户账号监听模式，有账号风控风险，需自行确认可接受
DISCORD_MODE=bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_USER_TOKEN=your_discord_user_token_here
DISCORD_SELF_ALLOW_SEND=false
DISCORD_MONITOR_CHANNELS=123456789012345678,987654321098765432

# WxPusher 配置
WXPUSHER_DEVICE_TOKEN=your_wxpusher_device_token_here
WXPUSHER_PUSH_TOKEN=your_wxpusher_push_token_here
WXPUSHER_DEVICE_UUID=your_wxpusher_device_uuid_here
WXPUSHER_PLATFORM=Chrome-Windows
WXPUSHER_VERSION=1.1.1
WXPUSHER_POLL_INTERVAL_SECONDS=60
WXPUSHER_ENABLE_POLLING=false
WXPUSHER_ENABLE_WEBSOCKET=false

# 线上 MySQL 存储。MySQL 不开放公网，本机开发请先建立 SSH 隧道。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=13306
MYSQL_USER=kol_app
MYSQL_PASSWORD=your_online_mysql_password_here
MYSQL_DATABASE=kol_monitor_trade
MYSQL_CHARSET=utf8mb4

# Trading, defaults to audit only.
TRADING_ENABLED=false
TRADING_EXECUTION_MODE=dry_run
TRADING_CREDENTIAL_DATABASE=market_opinion_tracker
TRADING_PROXY_URL=
TRADING_ACCOUNT_EQUITY_USDT=100
TRADING_MAX_STOP_LOSS_PERCENT=5
TRADING_MAX_ORDER_RISK_USDT=0
TRADING_MAX_SIGNAL_AGE_SECONDS=900
TRADING_MARGIN_MODE=crossed
TRADING_PRODUCT_TYPE=USDT-FUTURES
TRADING_MARGIN_COIN=USDT

# 仓位变动通知。微信接收优先用 WxPusher。
POSITION_NOTIFY_ENABLED=false
POSITION_NOTIFY_CHANNEL=wxpusher
POSITION_NOTIFY_INTERVAL_SECONDS=30
POSITION_NOTIFY_WXPUSHER_SPT=
POSITION_NOTIFY_WXPUSHER_APP_TOKEN=
POSITION_NOTIFY_WXPUSHER_UIDS=
POSITION_NOTIFY_WXPUSHER_TOPIC_IDS=

# 可选：跨平台转发规则
# [{"source":"telegram","source_channel":"-1001234567890","target":"discord","target_channel":"123456789012345678"}]
FORWARD_RULES=[]

# Web 服务
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
